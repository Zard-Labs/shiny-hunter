{
  "name": "Static Encounter Hunt (Battle Sparkle)",
  "description": "Shiny hunt for static/legendary encounters. Save in front, interact to trigger battle, detect shiny via battle-entry sparkle animation, soft reset if not shiny. Requires battle-screen and overworld template images.",
  "game": "Pokemon FireRed/LeafGreen",
  "pokemon_name": "Legendary",
  "definition": {
    "version": 1,
    "detection": {
      "method": "battle_sparkle",
      "zone": {
        "upper_x": 320,
        "upper_y": 40,
        "lower_x": 580,
        "lower_y": 200
      },
      "spark_threshold": 500,
      "peak_threshold": 1000,
      "min_spike_frames": 3,
      "spike_delta_pct": 0.15,
      "min_variance": 50.0,
      "color_bounds": {
        "lower_hsv": [0, 0, 200],
        "upper_hsv": [60, 100, 255]
      }
    },
    "gender_detection": {
      "enabled": false,
      "zone": {}
    },
    "nature_detection": {
      "enabled": false,
      "zone": {}
    },
    "soft_reset": {
      "hold_duration": 0.5,
      "wait_after": 3,
      "max_retries": 3
    },
    "steps": [
      {
        "name": "BOOT",
        "display_name": "Boot and Navigate Menus",
        "type": "navigate",
        "cooldown": 0.6,
        "rules": [
          {
            "condition": {
              "type": "template_match",
              "template": "overworld",
              "threshold": 0.85
            },
            "actions": [],
            "transition": "INTERACT"
          }
        ],
        "default_action": [
          { "type": "press_button", "button": "A" }
        ]
      },
      {
        "name": "INTERACT",
        "display_name": "Interacting with Pokemon",
        "type": "navigate",
        "cooldown": 0.5,
        "rules": [
          {
            "condition": {
              "type": "template_match",
              "template": "battle_screen",
              "threshold": 0.8
            },
            "actions": [],
            "transition": "BATTLE_ENTRY"
          }
        ],
        "default_action": [
          { "type": "press_button", "button": "A", "wait": 0.5 }
        ]
      },
      {
        "name": "BATTLE_ENTRY",
        "display_name": "Battle Entry - Waiting for Pokemon",
        "type": "timed_wait",
        "duration": 2.0,
        "during_wait_action": [],
        "transition": "BATTLE_SPARKLE_CHECK"
      },
      {
        "name": "BATTLE_SPARKLE_CHECK",
        "display_name": "Checking for Shiny Sparkle",
        "type": "battle_shiny_check",
        "pre_check_delay": 0.5,
        "capture_window_seconds": 1.5,
        "ring_buffer_frames": 90,
        "analysis_frames": 45,
        "spark_threshold": 500,
        "peak_threshold": 1000,
        "min_spike_frames": 3,
        "spike_delta_pct": 0.15,
        "min_variance": 50.0,
        "on_shiny": "STOP",
        "on_normal_actions": [
          { "type": "soft_reset" }
        ],
        "on_normal_transition": "BOOT"
      }
    ]
  },
  "images": [
    {
      "key": "title_screen",
      "label": "Title Screen",
      "description": "The game's main title/start screen",
      "threshold": 0.80
    },
    {
      "key": "load_game",
      "label": "Load Game Menu",
      "description": "The Continue / load save menu",
      "threshold": 0.80
    },
    {
      "key": "overworld",
      "label": "Overworld",
      "description": "Standing in front of the legendary Pokemon",
      "threshold": 0.80
    },
    {
      "key": "battle_screen",
      "label": "Battle Screen",
      "description": "The battle screen showing the enemy Pokemon",
      "threshold": 0.80
    }
  ]
}
